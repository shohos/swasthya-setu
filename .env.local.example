# ---------- AI keys (both free tier) ----------

# Google Gemini API key — powers ALL LLM features:
# Bangla chatbot (streaming), clinical triage, prescription structuring,
# and generic-substitution explanations.
# Free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Roboflow API key — powers ALL computer vision:
# anemia/jaundice eye screening (hosted CLIP zero-shot verification) and
# prescription OCR (hosted DocTR model). Free tier.
# Get it at https://app.roboflow.com → Settings → API Keys (Private API Key).
ROBOFLOW_API_KEY=your_roboflow_key_here

# Without keys the app still runs: every AI endpoint falls back to
# pre-computed demo responses (labeled as demo mode in the UI).

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=file:./swasthya.db
