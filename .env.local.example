# Anthropic API key — get one at https://platform.claude.com
# Without a key the app still runs: every AI endpoint falls back to
# pre-computed demo responses so the demo never breaks.
ANTHROPIC_API_KEY=your_key_here

# Claude model (optional). Defaults to claude-sonnet-4-6.
# CLAUDE_MODEL=claude-sonnet-4-6

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=file:./swasthya.db
